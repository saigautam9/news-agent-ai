# =============================================================
#  NewsAgent AI — environment variables
#  Copy this file to .env.local and fill in the values.
#  All providers below have FREE tiers — total cost: $0 forever.
# =============================================================

# --- Google Gemini (free) — Fetcher, Analyst, Classifier, Impact Mapper ---
# Get a free key at https://aistudio.google.com/apikey  (see SETUP.md)
GEMINI_API_KEY=AIxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Groq (free) — Historian, Synthesis, plain-English Rewriter ---
# Get a free key at https://console.groq.com/keys  (see SETUP.md)
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Telegram bot (free) — daily briefing + breaking-news notifications ---
# Create a bot with @BotFather, then find your chat id. See README.md.
TELEGRAM_BOT_TOKEN=123456789:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TELEGRAM_CHAT_ID=123456789

# Interactive bot: secret shared between Telegram and the /api/telegram webhook
# so only Telegram can trigger it. Any random string — generate one with:
#   openssl rand -hex 16
# Then register the webhook after deploy:  python scripts/setup_webhook.py set <url>
TELEGRAM_WEBHOOK_SECRET=

# --- App URL ---
# Used for the "Open NewsAgent AI" link in Telegram messages.
# Set to your deployed URL once live (e.g. https://deep-signal.vercel.app).
APP_URL=http://localhost:8000

# --- Cost protection — hard daily caps for the automated jobs ---
# The schedule uses ~18 Gemini calls/day (12 monitor scans + 3 briefings).
# Gemini's free tier allows 20 requests/day per model — keep the caps near that.
# If a cap is hit the job stops cleanly and resumes the next day.
MAX_GEMINI_CALLS=20
MAX_GROQ_CALLS=20
# Send a Telegram warning once usage crosses this fraction of a cap.
USAGE_WARN_THRESHOLD=0.8

# --- Optional: model overrides (defaults shown) ---
GEMINI_MODEL=gemini-2.5-flash
GEMINI_LITE_MODEL=gemini-2.5-flash-lite
GROQ_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
